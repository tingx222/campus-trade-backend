<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campus.trade.mapper.UserMapper">

    <resultMap id="userResultMap" type="com.campus.trade.entity.User">
        <id property="id" column="id"/>
        <result property="phone" column="phone"/>
        <result property="password" column="password"/>
        <result property="nickname" column="nickname"/>
        <result property="creditScore" column="credit_score"/>
        <result property="isAuth" column="is_auth"/>
        <result property="role" column="role"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <sql id="userColumns">
        id, phone, password, nickname, credit_score, is_auth, role, create_time
    </sql>

    <select id="findByPhone" resultMap="userResultMap">
        SELECT <include refid="userColumns"/>
        FROM user
        WHERE phone = #{phone}
    </select>

    <select id="findById" resultMap="userResultMap">
        SELECT <include refid="userColumns"/>
        FROM user
        WHERE id = #{id}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user (phone, password, nickname, credit_score, is_auth, role, create_time)
        VALUES (#{phone}, #{password}, #{nickname}, #{creditScore}, #{isAuth}, #{role}, #{createTime})
    </insert>

    <update id="update">
        UPDATE user
        <set>
            <if test="nickname != null">nickname = #{nickname},</if>
            <if test="password != null">password = #{password},</if>
            <if test="creditScore != null">credit_score = #{creditScore},</if>
            <if test="isAuth != null">is_auth = #{isAuth},</if>
            <if test="role != null">role = #{role},</if>
        </set>
        WHERE id = #{id}
    </update>

</mapper>